# =============================================================================
# CES LMS Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env file to version control
# =============================================================================

# -----------------------------------------------------------------------------
# MONGODB ATLAS CONFIGURATION (REQUIRED)
# -----------------------------------------------------------------------------
# Get your connection string from MongoDB Atlas:
# 1. Go to https://cloud.mongodb.com
# 2. Click "Connect" on your cluster
# 3. Choose "Connect your application"
# 4. Copy the connection string and replace <password> with your password
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ces-lms?retryWrites=true&w=majority
MONGODB_DB_NAME=ces-lms

# -----------------------------------------------------------------------------
# JWT AUTHENTICATION (REQUIRED)
# -----------------------------------------------------------------------------
# Generate secure secrets using: openssl rand -base64 32
# IMPORTANT: Use different values for JWT_SECRET and JWT_REFRESH_SECRET
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-characters-long
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# -----------------------------------------------------------------------------
# FRONTEND API CONFIGURATION (REQUIRED FOR PRODUCTION)
# -----------------------------------------------------------------------------
# Replace YOUR_SERVER_IP with your actual Azure VM public IP or domain name
# This is baked into the frontend build, so changes require rebuild
VITE_API_BASE_URL=http://YOUR_SERVER_IP:3000
VITE_API_VERSION=v1
VITE_API_TIMEOUT=30000

# -----------------------------------------------------------------------------
# CORS CONFIGURATION
# -----------------------------------------------------------------------------
# For development: use * to allow all origins
# For production: use your frontend URL (e.g., http://YOUR_SERVER_IP)
CORS_ORIGIN=*
CORS_CREDENTIALS=true

# -----------------------------------------------------------------------------
# OPTIONAL CONFIGURATIONS (Have sensible defaults)
# -----------------------------------------------------------------------------

# Node Environment
NODE_ENV=production

# Backend Port (default: 3000)
# PORT=3000

# API Version (default: v1)
# API_VERSION=v1

# Password Hashing Rounds (default: 12, higher = more secure but slower)
# BCRYPT_ROUNDS=12

# Rate Limiting (default: 100 requests per 15 minutes)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# File Upload (default: 10MB)
# MAX_FILE_SIZE=10485760
# UPLOAD_DIR=uploads

# Logging (default: info, options: error, warn, info, debug)
# LOG_LEVEL=info
# LOG_DIR=logs

# -----------------------------------------------------------------------------
# DATABASE SEEDING (ONE-TIME USE)
# -----------------------------------------------------------------------------
# Set to true ONLY on first deployment to populate test data
# Set back to false after seeding is complete
RUN_SEED=false

# =============================================================================
# QUICK START CHECKLIST
# =============================================================================
# [ ] 1. Set MONGODB_URI to your MongoDB Atlas connection string
# [ ] 2. Generate and set JWT_SECRET (openssl rand -base64 32)
# [ ] 3. Generate and set JWT_REFRESH_SECRET (openssl rand -base64 32)
# [ ] 4. Set VITE_API_BASE_URL to http://YOUR_AZURE_VM_IP:3000
# [ ] 5. (Optional) Set RUN_SEED=true for first deployment to add test data
# =============================================================================
